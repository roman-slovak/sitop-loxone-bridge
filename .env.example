# --- SITOP PSU8600 OPC UA server ---
OPCUA_URL=opc.tcp://192.168.1.112:4840
OPCUA_USERNAME=
OPCUA_PASSWORD=
OPCUA_SESSION_TIMEOUT_MS=120000

# AC line input voltage (single node).
OPCUA_NODE_INPUT_VOLTAGE=ns=3;i=100641

# Per-output OutputVoltage / OutputCurrent NodeIds, paired by index.
# Total DC output power sent to Loxone = sum(Vi * Ii) * POWER_EFFICIENCY_FACTOR.
# Total DC output current = sum(Ii).
OPCUA_NODES_OUTPUT_VOLTAGE=ns=3;i=100069,ns=3;i=100139,ns=3;i=100209,ns=3;i=100279
OPCUA_NODES_OUTPUT_CURRENT=ns=3;i=100061,ns=3;i=100131,ns=3;i=100201,ns=3;i=100271

# 1.0  = report raw DC output power (under-counts AC consumption by ~5-10%)
# 1.075 = estimate AC consumption assuming ~93% efficiency
POWER_EFFICIENCY_FACTOR=1.0

# --- Loxone Miniserver ---
LOXONE_SCHEME=http
LOXONE_HOST=192.168.1.10
LOXONE_USER=admin
LOXONE_PASS=changeme
LOXONE_VERIFY_SSL=true

# Names of Virtual HTTP Inputs configured in Loxone Config.
# Each value gets sent as: <scheme>://<host>/dev/sps/io/<VI_NAME>/<value>
LOXONE_VI_POWER=SITOP_Power
LOXONE_VI_VOLTAGE=SITOP_Voltage
LOXONE_VI_CURRENT=SITOP_Current

POLL_INTERVAL_SECONDS=5
LOG_LEVEL=INFO
