# --- SITOP PSU8600 OPC UA server ---
OPCUA_URL=opc.tcp://192.168.1.112:4840
OPCUA_USERNAME=
OPCUA_PASSWORD=
OPCUA_SESSION_TIMEOUT_MS=120000

# --- Loxone Miniserver ---
LOXONE_SCHEME=http
LOXONE_HOST=192.168.1.10
LOXONE_USER=admin
LOXONE_PASS=changeme
LOXONE_VERIFY_SSL=true

# --- Bridge runtime ---
POLL_INTERVAL_SECONDS=5
LOG_LEVEL=INFO
# Bridge is reported unhealthy if last_tick is older than this many seconds.
# Conservative default (60 s) tolerates OPC UA reconnect backoff (max ~60 s).
HEALTH_FRESH_WINDOW_S=60

# --- Web UI (sitop-web service) ---
WEB_HOST=0.0.0.0
WEB_PORT=8767

# DATA_DIR is fixed to /data inside the containers (named volume sitop_data).
# Selected parameters live in /data/selection.yaml; runtime state in
# /data/runtime_state.json. Both are generated by the web UI / bridge.
